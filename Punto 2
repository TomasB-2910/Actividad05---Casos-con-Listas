]).

## Conexiones entre ciudades con costo
conexion(ciudad(vancouver,  british_columbia, 675218),  ciudad(edmonton,  alberta,       981280),  16).
conexion(ciudad(vancouver,  british_columbia, 675218),  ciudad(calgary,   alberta,       1336000), 13).
conexion(ciudad(edmonton,   alberta,          981280),  ciudad(saskatoon, saskatchewan,  273010),  12).
conexion(ciudad(saskatoon,  saskatchewan,     273010),  ciudad(winnipeg,  manitoba,      749607),  20).
